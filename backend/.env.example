# ─── Environment ──────────────────────────────────────────────────────────────
ENV=development

# ─── Security ─────────────────────────────────────────────────────────────────
# Must be a random string of 32+ chars in production.
SECRET_KEY=change-me-32-chars-min

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://xyz_platform:xyz_platform@postgres:5432/xyz_platform
ALEMBIC_DATABASE_URL=postgresql+psycopg2://xyz_platform:xyz_platform@postgres:5432/xyz_platform

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Code Execution ───────────────────────────────────────────────────────────
JUDGE0_URL=http://judge0-server:2358
USE_LOCAL_JUDGE=true

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Token ────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Rate Limiting ────────────────────────────────────────────────────────────
MAX_SUBMISSIONS_PER_MINUTE=10
MAX_REQUESTS_PER_MINUTE_IP=100
MAX_SOURCE_BYTES=65536
# true  → fail-open  (allow requests if Redis is down) — suitable for dev/staging
# false → fail-closed (deny requests if Redis is down) — required for production
RATE_LIMIT_FAIL_OPEN=true

# ─── Worker ───────────────────────────────────────────────────────────────────
RECLAIM_ALL_RUNNING_ON_START=false

# ─── Seed admin account ───────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@xyz-platform.local
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin12345

# ─── URLs (for OAuth redirects) ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ─── OAuth Providers ──────────────────────────────────────────────────────────
# Register your app at:
#   Google:   https://console.cloud.google.com/apis/credentials
#   GitHub:   https://github.com/settings/developers
#   LinkedIn: https://www.linkedin.com/developers/apps
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Dev-only convenience bypass — MUST remain false in all non-development environments
ENABLE_MOCK_OAUTH=false

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Fill in to enable real password-reset emails.
# Leave blank → OTP surfaced in server logs and API response (dev_code field, dev only).
#
# Gmail (App Password):
#   SMTP_HOST=smtp.gmail.com | SMTP_PORT=587 | SMTP_TLS=true | SMTP_SSL=false
#   Create an App Password at: https://myaccount.google.com/apppasswords
#
# SendGrid SMTP relay:
#   SMTP_HOST=smtp.sendgrid.net | SMTP_PORT=587 | SMTP_USER=apikey
#   SMTP_PASSWORD=<your SendGrid API key>
#
# AWS SES SMTP:
#   SMTP_HOST=email-smtp.<region>.amazonaws.com | SMTP_PORT=587
#   SMTP_USER=<SES SMTP username> | SMTP_PASSWORD=<SES SMTP password>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=bugX <noreply@example.com>
SMTP_TLS=true
SMTP_SSL=false
